<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.bioskop.helloworld.TiketController"
            stylesheets="@Tiket.css">

    <!-- ================= HEADER ================= -->

    <top>

        <HBox alignment="CENTER"
              styleClass="header">

            <Label text="TIKET BIOSKOP"
                   styleClass="header-title"/>

        </HBox>

    </top>

    <!-- ================= CONTENT ================= -->

    <center>

        <ScrollPane fitToWidth="true">

            <content>

                <VBox alignment="CENTER"
                      spacing="25"
                      style="-fx-padding:25;">

                    <!-- KARTU TIKET -->

                    <VBox spacing="18"
                          alignment="CENTER"
                          prefWidth="700"
                          styleClass="ticket-card">

                        <Label text="CINEMAX"
                               styleClass="cinema-title"/>

                        <Separator/>

                        <ImageView fx:id="posterImage"
                                   fitWidth="220"
                                   fitHeight="300"
                                   preserveRatio="true"/>

                        <Separator/>

                        <HBox>

                            <Label text="Film"
                                   styleClass="normal-label"/>

                            <Region HBox.hgrow="ALWAYS"/>

                            <Label fx:id="judulLabel"
                                   text="-"
                                   styleClass="info-label"/>

                        </HBox>

                        <HBox>

                            <Label text="Studio"
                                   styleClass="normal-label"/>

                            <Region HBox.hgrow="ALWAYS"/>

                            <Label fx:id="studioLabel"
                                   text="-"
                                   styleClass="info-label"/>

                        </HBox>

                        <HBox>

                            <Label text="Tanggal"
                                   styleClass="normal-label"/>

                            <Region HBox.hgrow="ALWAYS"/>

                            <Label fx:id="tanggalLabel"
                                   text="-"
                                   styleClass="info-label"/>

                        </HBox>

                        <HBox>

                            <Label text="Jam"
                                   styleClass="normal-label"/>

                            <Region HBox.hgrow="ALWAYS"/>

                            <Label fx:id="jamLabel"
                                   text="-"
                                   styleClass="info-label"/>

                        </HBox>
                        <HBox>

                            <Label text="Kursi"
                                   styleClass="normal-label"/>

                            <Region HBox.hgrow="ALWAYS"/>

                            <Label fx:id="kursiLabel"
                                   text="-"
                                   styleClass="info-label"/>

                        </HBox>

                        <HBox>

                            <Label text="Harga"
                                   styleClass="normal-label"/>

                            <Region HBox.hgrow="ALWAYS"/>

                            <Label fx:id="hargaLabel"
                                   text="Rp0"
                                   styleClass="info-label"/>

                        </HBox>

                        <Separator/>

                        <VBox alignment="CENTER"
                              spacing="8">

                            <Label text="KODE BOOKING"
                                   styleClass="booking-title"/>

                            <Label fx:id="kodeLabel"
                                   text="-"
                                   styleClass="booking-code"/>

                        </VBox>

                    </VBox>

                    <!-- TOMBOL -->

                    <VBox alignment="CENTER"
                          spacing="15">

                        <Button fx:id="btnCetak"
                                text="CETAK TIKET"
                                prefWidth="300"
                                prefHeight="45"
                                onAction="#cetakTiket"
                                styleClass="print-button"/>

                        <Button fx:id="btnSelesai"
                                text="SELESAI"
                                prefWidth="300"
                                prefHeight="45"
                                onAction="#selesai"
                                styleClass="finish-button"/>

                    </VBox>

                </VBox>

            </content>

        </ScrollPane>

    </center>

</BorderPane>