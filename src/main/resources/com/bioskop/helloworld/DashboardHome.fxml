<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<ScrollPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.bioskop.helloworld.DashboardHomeController"
            fitToWidth="true"
            style="-fx-background:#0f0f0f;
                   -fx-background-color:#0f0f0f;">

    <content>

        <VBox spacing="20"
              style="-fx-padding:20; -fx-background-color:#0f0f0f;">

            <!-- HEADER -->
            <VBox spacing="5">

                <Label text="Halo Janson"
                       style="-fx-text-fill:white;
                              -fx-font-size:28;
                              -fx-font-weight:bold;"/>

                <Label text="Selamat Bertugas Hari Ini!!"
                       style="-fx-text-fill:#bdbdbd;"/>

            </VBox>

            <!-- KARTU STATISTIK -->
            <HBox spacing="15">

                <VBox prefWidth="180"
                      spacing="10"
                      style="-fx-background-color:#1f1f1f;
                             -fx-background-radius:15;
                             -fx-padding:15;">

                    <Label text="🎟️ Tiket Terjual"
                           style="-fx-text-fill:#bdbdbd;"/>

                    <Label text="128"
                           style="-fx-text-fill:white;
                                  -fx-font-size:28;
                                  -fx-font-weight:bold;"/>

                </VBox>

                <VBox prefWidth="180"
                      spacing="10"
                      style="-fx-background-color:#1f1f1f;
                             -fx-background-radius:15;
                             -fx-padding:15;">

                    <Label text="💰 Pendapatan"
                           style="-fx-text-fill:#bdbdbd;"/>

                    <Label text="Rp 4.250.000"
                           style="-fx-text-fill:white;
                                  -fx-font-size:28;
                                  -fx-font-weight:bold;"/>

                </VBox>

                <VBox prefWidth="180"
                      spacing="10"
                      style="-fx-background-color:#1f1f1f;
                             -fx-background-radius:15;
                             -fx-padding:15;">

                    <Label text="🎬 Film Tayang"
                           style="-fx-text-fill:#bdbdbd;"/>

                    <Label text="8"
                           style="-fx-text-fill:white;
                                  -fx-font-size:28;
                                  -fx-font-weight:bold;"/>

                </VBox>

                <VBox prefWidth="180"
                      spacing="10"
                      style="-fx-background-color:#1f1f1f;
                             -fx-background-radius:15;
                             -fx-padding:15;">

                    <Label text="🏢 Studio Aktif"
                           style="-fx-text-fill:#bdbdbd;"/>

                    <Label text="5"
                           style="-fx-text-fill:white;
                                  -fx-font-size:28;
                                  -fx-font-weight:bold;"/>

                </VBox>

            </HBox>

            <!-- FILM -->
            <Label text="Film Sedang Tayang"
                   style="-fx-text-fill:white;
                          -fx-font-size:22;
                          -fx-font-weight:bold;"/>

            <HBox spacing="15">

                <!-- FILM 1 -->
                <VBox alignment="CENTER"
                      prefWidth="180"
                      spacing="10"
                      style="-fx-background-color:#1f1f1f;
                             -fx-background-radius:15;
                             -fx-padding:15;">

                    <ImageView fx:id="pacificRimImg"
                                fitWidth="150"
                               fitHeight="180"
                               preserveRatio="true"/>

                    <Label text="Pacific Rim"
                           style="-fx-text-fill:white;
                                  -fx-font-weight:bold;"/>

                    <Label text="Sci-Fi"
                           style="-fx-text-fill:#bdbdbd;"/>

                    <Button text="Pilih Film"
                            style="-fx-background-color:#c62828;
                                   -fx-text-fill:white;"/>

                </VBox>

                <!-- FILM 2 -->
                <VBox alignment="CENTER"
                      prefWidth="180"
                      spacing="10"
                      style="-fx-background-color:#1f1f1f;
                             -fx-background-radius:15;
                             -fx-padding:15;">

                    <ImageView fx:id="moana1Img"
                                fitWidth="150"
                               fitHeight="180"
                               preserveRatio="true"/>

                    <Label text="Moana 1"
                           style="-fx-text-fill:white;
                                  -fx-font-weight:bold;"/>

                    <Label text="Animation"
                           style="-fx-text-fill:#bdbdbd;"/>

                    <Button text="Pilih Film"
                            style="-fx-background-color:#c62828;
                                   -fx-text-fill:white;"/>

                </VBox>

                <!-- FILM 3 -->
                <VBox alignment="CENTER"
                      prefWidth="180"
                      spacing="10"
                      style="-fx-background-color:#1f1f1f;
                             -fx-background-radius:15;
                             -fx-padding:15;">

                    <ImageView fx:id="ingloriousImg"
                                fitWidth="150"
                               fitHeight="180"
                               preserveRatio="true"/>

                    <Label text="Inglorious Basterds"
                           style="-fx-text-fill:white;
                                  -fx-font-weight:bold;"/>

                    <Label text="History"
                           style="-fx-text-fill:#bdbdbd;"/>

                    <Button text="Pilih Film"
                            style="-fx-background-color:#c62828;
                                   -fx-text-fill:white;"/>

                </VBox>

                <!-- FILM 4 -->
                <VBox alignment="CENTER"
                      prefWidth="180"
                      spacing="10"
                      style="-fx-background-color:#1f1f1f;
                             -fx-background-radius:15;
                             -fx-padding:15;">

                    <ImageView fx:id="Moana2Img"
                                fitWidth="150"
                               fitHeight="180"
                               preserveRatio="true"/>

                    <Label text="Moana 2"
                           style="-fx-text-fill:white;
                                  -fx-font-weight:bold;"/>

                    <Label text="Action"
                           style="-fx-text-fill:#bdbdbd;"/>

                    <Button text="Pilih Film"
                            style="-fx-background-color:#c62828;
                                   -fx-text-fill:white;"/>

                </VBox>

            </HBox>

            <!-- TRANSAKSI -->
            <Label text="Transaksi Terbaru"
                   style="-fx-text-fill:white;
                          -fx-font-size:22;
                          -fx-font-weight:bold;"/>

            <TableView prefHeight="250">

                <columns>

                    <TableColumn text="Invoice"
                                 prefWidth="120"/>

                    <TableColumn text="Film"
                                 prefWidth="220"/>

                    <TableColumn text="Jumlah Tiket"
                                 prefWidth="120"/>

                    <TableColumn text="Total"
                                 prefWidth="150"/>

                </columns>

            </TableView>

        </VBox>

    </content>

</ScrollPane>