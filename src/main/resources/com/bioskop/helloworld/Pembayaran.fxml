<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.bioskop.helloworld.PembayaranController"
            stylesheets="@Pembayaran.css">

    <top>

        <HBox alignment="CENTER_LEFT"
              spacing="20"
              styleClass="header">

            <Button text="← Kembali"
                    fx:id="btnKembali"
                    onAction="#kembali"
                    styleClass="back-button"/>

            <Label text="PEMBAYARAN"
                   styleClass="header-title"/>

        </HBox>

    </top>

    <center>

        <ScrollPane fitToWidth="true">

            <content>

                <VBox spacing="25"
                      alignment="TOP_CENTER"
                      style="-fx-padding:25;">

                    <HBox spacing="30"
                          alignment="TOP_CENTER">

                        <!-- INFORMASI FILM -->

                        <VBox spacing="20"
                              prefWidth="430"
                              styleClass="card">

                            <ImageView fx:id="posterImage"
                                       fitWidth="240"
                                       fitHeight="330"
                                       preserveRatio="true"/>

                            <Label text="Informasi Film"
                                   styleClass="section-title"/>

                            <HBox spacing="10">

                                <Label text="Judul"
                                       styleClass="normal-label"/>

                                <Region HBox.hgrow="ALWAYS"/>

                                <Label fx:id="judulLabel"
                                       text="-"
                                       styleClass="info-label"/>

                            </HBox>

                            <Separator/>

                            <HBox spacing="10">

                                <Label text="Studio"
                                       styleClass="normal-label"/>

                                <Region HBox.hgrow="ALWAYS"/>

                                <Label fx:id="studioLabel"
                                       text="-"
                                       styleClass="info-label"/>

                            </HBox>

                            <Separator/>

                            <HBox spacing="10">

                                <Label text="Tanggal"
                                       styleClass="normal-label"/>

                                <Region HBox.hgrow="ALWAYS"/>

                                <Label fx:id="tanggalLabel"
                                       text="-"
                                       styleClass="info-label"/>

                            </HBox>

                            <Separator/>

                            <HBox spacing="10">

                                <Label text="Jam"
                                       styleClass="normal-label"/>

                                <Region HBox.hgrow="ALWAYS"/>

                                <Label fx:id="jamLabel"
                                       text="-"
                                       styleClass="info-label"/>

                            </HBox>

                            <Separator/>

                            <HBox spacing="10">

                                <Label text="Kursi"
                                       styleClass="normal-label"/>

                                <Region HBox.hgrow="ALWAYS"/>

                                <Label fx:id="kursiLabel"
                                       text="-"
                                       styleClass="info-label"/>

                            </HBox>

                        </VBox>

                        <!-- RINGKASAN -->

                        <VBox spacing="18"
                              prefWidth="430"
                              styleClass="card">

                            <Label text="Ringkasan Pembayaran"
                                   styleClass="section-title"/>

                            <HBox>

                                <Label text="Jumlah Tiket"
                                       styleClass="normal-label"/>

                                <Region HBox.hgrow="ALWAYS"/>

                                <Label fx:id="jumlahLabel"
                                       text="0"
                                       styleClass="info-label"/>

                            </HBox>

                            <Separator/>

                            <HBox>

                                <Label text="Harga Tiket"
                                       styleClass="normal-label"/>

                                <Region HBox.hgrow="ALWAYS"/>

                                <Label fx:id="hargaLabel"
                                       text="Rp0"
                                       styleClass="info-label"/>

                            </HBox>

                            <Separator/>

                            <HBox>

                                <Label text="Biaya Admin"
                                       styleClass="normal-label"/>

                                <Region HBox.hgrow="ALWAYS"/>

                                <Label fx:id="adminLabel"
                                       text="Rp2.500"
                                       styleClass="info-label"/>

                            </HBox>

                            <Separator/>

                            <HBox>

                                <Label text="TOTAL"
                                       styleClass="section-title"/>

                                <Region HBox.hgrow="ALWAYS"/>

                                <Label fx:id="totalLabel"
                                       text="Rp0"
                                       styleClass="total-price"/>

                            </HBox>

                            <Separator/>

                            <Label text="Metode Pembayaran"
                                   styleClass="section-title"/>

                            <ComboBox fx:id="metodeBox"
                                      prefWidth="350"
                                      promptText="Pilih Metode Pembayaran"/>
                            <VBox spacing="15"
                                  style="-fx-padding:15 0 0 0;">

                                <Button fx:id="btnBayar"
                                        text="BAYAR SEKARANG"
                                        prefWidth="350"
                                        prefHeight="50"
                                        onAction="#bayar"
                                        styleClass="pay-button"/>

                                <Button fx:id="btnBatal"
                                        text="BATAL"
                                        prefWidth="350"
                                        prefHeight="45"
                                        onAction="#kembali"
                                        styleClass="cancel-button"/>

                            </VBox>

                        </VBox>

                    </HBox>

                </VBox>

            </content>

        </ScrollPane>

    </center>

</BorderPane>
