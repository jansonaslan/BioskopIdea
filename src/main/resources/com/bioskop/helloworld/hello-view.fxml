<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.image.ImageView?>

<AnchorPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.bioskop.helloworld.HelloController">

    <ImageView fx:id="backgroundImage"
               fitWidth="1600"
               fitHeight="900"
               preserveRatio="false"/>

    <VBox alignment="CENTER"
          layoutX="550"
          layoutY="120"
          spacing="10"
          prefWidth="500"
          prefHeight="600"
          style="-fx-background-color: rgba(20,20,20,0.8);
                 -fx-background-radius: 30;
                 -fx-padding: 40;
                 -fx-border-color: rgba(255,255,255,0.2);
                 -fx-border-radius: 30;">

        <Label text="🎥"
               style="
                -fx-font-size: 100px;
                -fx-text-fill: white;
                "/>

        <Label text="Selamat Datang!"
               style="
                -fx-font-size: 50px;
                -fx-font-weight: bold;
                -fx-text-fill: white;"/>

        <Label text="Masuk untuk melanjutkan pengalaman"
               style="
                -fx-font-size: 20px;
                -fx-text-fill: white;"/>

        <Label text="Menonton terbaik"
               style="
                -fx-font-size: 18px;
                -fx-text-fill: white;"/>

        <TextField fx:id="usernameField"
                   promptText="Input Username"
                   prefWidth="350"
                   prefHeight="45"
                   style="
                    -fx-background-radius: 15px;
                    -fx-font-size: 15px;"/>

        <PasswordField fx:id="passwordField"
                       promptText="Input Password"
                       prefWidth="350"
                       prefHeight="45"
                       style="
                   -fx-background-radius: 15px;
                    -fx-font-size: 15px;"/>

        <Button text="Login"
                onAction="#login"
                prefWidth="350"
                prefHeight="45"
                style="
                -fx-background-color: #B71C1C;
                -fx-text-fill: white;
                -fx-font-size: 16px;
                -fx-font-weight: bold;
                -fx-background-radius: 15px;"/>

        <Label fx:id="statusLabel"
               style="
            -fx-text-fill: white;
            -fx-font-size: 14px;"/>

    </VBox>
</AnchorPane>
