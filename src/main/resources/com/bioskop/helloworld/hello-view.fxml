<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Pos?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>

<StackPane xmlns:fx="http://javafx.com/fxml"
           fx:controller="com.bioskop.helloworld.LoginController">

    <!-- Background -->
    <ImageView fx:id="backgroundImage"
               preserveRatio="false"
               fitWidth="1920"
               fitHeight="1080"
               StackPane.alignment="CENTER"/>

    <!-- Login Card -->
    <VBox alignment="CENTER"
          spacing="12"
          maxWidth="500"
          maxHeight="600"
          style="-fx-background-color: rgba(20,20,20,0.80);
                 -fx-background-radius:30;
                 -fx-padding:40;
                 -fx-border-color:rgba(255,255,255,0.2);
                 -fx-border-radius:30;">

        <Label text="🎥"
               style="-fx-font-size:90;
                      -fx-text-fill:white;"/>

        <Label text="Selamat Datang!"
               style="-fx-font-size:42;
                      -fx-font-weight:bold;
                      -fx-text-fill:white;"/>

        <Label text="Masuk untuk melanjutkan pengalaman menonton"
               style="-fx-font-size:18;
                      -fx-text-fill:white;"/>

        <TextField fx:id="txtUsername"
                   promptText="Username"
                   prefWidth="350"
                   prefHeight="45"/>

        <PasswordField fx:id="txtPassword"
                       promptText="Password"
                       prefWidth="350"
                       prefHeight="45"/>

        <Button text="Login"
                onAction="#login"
                prefWidth="350"
                prefHeight="45"
                style="-fx-background-color:#c62828;
                       -fx-text-fill:white;
                       -fx-font-size:16;
                       -fx-font-weight:bold;"/>

        <Label fx:id="statusLabel"
               style="-fx-text-fill:white;"/>

    </VBox>

</StackPane>