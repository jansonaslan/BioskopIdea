<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.bioskop.helloworld.SeatController"
            stylesheets="@seat.css">

    <!-- ================= HEADER ================= -->

    <top>

        <HBox spacing="20"
              alignment="CENTER_LEFT"
              styleClass="header">

            <Button fx:id="btnKembali"
                    text="← Kembali"
                    onAction="#kembali"
                    styleClass="back-button"/>

            <Label text="PILIH KURSI"
                   styleClass="header-title"/>

        </HBox>

    </top>

    <!-- ================= CONTENT ================= -->

    <center>

        <ScrollPane fitToWidth="true"
                    styleClass="scroll-pane">

            <content>

                <VBox spacing="25"
                      alignment="TOP_CENTER"
                      style="-fx-padding:25;">

                    <!-- SCREEN -->

                    <Label text="LAYAR BIOSKOP"
                           styleClass="section-title"/>

                    <Region prefWidth="650"
                            prefHeight="12"
                            styleClass="screen"/>

                    <!-- SEAT -->

                    <HBox spacing="35"
                          alignment="CENTER">

                        <!-- BARIS -->

                        <VBox spacing="15"
                              alignment="CENTER">

                            <Label text="A" styleClass="normal-label"/>
                            <Label text="B" styleClass="normal-label"/>
                            <Label text="C" styleClass="normal-label"/>
                            <Label text="D" styleClass="normal-label"/>
                            <Label text="E" styleClass="normal-label"/>
                            <Label text="F" styleClass="normal-label"/>

                        </VBox>

                        <!-- KURSI -->

                        <FlowPane fx:id="seatPane"
                                  hgap="10"
                                  vgap="12"
                                  alignment="CENTER"
                                  prefWrapLength="430"/>

                    </HBox>

                    <HBox spacing="30" alignment="CENTER">

                        <HBox spacing="8" alignment="CENTER">
                            <Region prefWidth="18"
                                    prefHeight="18"
                                    style="-fx-background-color:#616161;
                       -fx-background-radius:4;"/>
                            <Label text="Kosong"
                                   styleClass="normal-label"/>
                        </HBox>

                        <HBox spacing="8" alignment="CENTER">
                            <Region prefWidth="18"
                                    prefHeight="18"
                                    style="-fx-background-color:#43a047;
                       -fx-background-radius:4;"/>
                            <Label text="Dipilih"
                                   styleClass="normal-label"/>
                        </HBox>

                        <HBox spacing="8" alignment="CENTER">
                            <Region prefWidth="18"
                                    prefHeight="18"
                                    style="-fx-background-color:#d32f2f;
                       -fx-background-radius:4;"/>
                            <Label text="Terisi"
                                   styleClass="normal-label"/>
                        </HBox>

                    </HBox>

                    <!-- RINGKASAN -->

                    <VBox spacing="12"
                          prefWidth="700"
                          alignment="CENTER_LEFT"
                          styleClass="card">

                        <Label text="Ringkasan Pesanan"
                               styleClass="section-title"/>

                        <HBox spacing="10">

                            <Label text="Jumlah Kursi :"
                                   styleClass="normal-label"/>

                            <Label fx:id="totalSeatLabel"
                                   text="0"
                                   styleClass="info-label"/>

                        </HBox>

                        <HBox spacing="10">

                            <Label text="Total Harga :"
                                   styleClass="normal-label"/>

                            <Label fx:id="totalHargaLabel"
                                   text="Rp0"
                                   styleClass="total-price"/>

                        </HBox>

                    </VBox>

                    <!-- BUTTON -->

                    <Button fx:id="btnLanjut"
                            text="LANJUT PEMBAYARAN"
                            prefWidth="350"
                            prefHeight="55"
                            onAction="#lanjutPembayaran"/>

                </VBox>

            </content>

        </ScrollPane>

    </center>

</BorderPane>